---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = (await getCollection('dien-toan-luong-tu')).sort(
		(a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
	);
	return posts.map((post, index) => ({
		params: { slug: post.id.replace(/\.[^/.]+$/, "") },
		props: { 
            post, 
            postIndex: index,
            prevPost: index > 0 ? posts[index - 1] : null,
            nextPost: index < posts.length - 1 ? posts[index + 1] : null
        },
	}));
}

type Props = {
    post: CollectionEntry<'dien-toan-luong-tu'>;
    postIndex: number;
    prevPost: CollectionEntry<'dien-toan-luong-tu'> | null;
    nextPost: CollectionEntry<'dien-toan-luong-tu'> | null;
};

const post = (Astro.props as any).post || (Astro.props as unknown as CollectionEntry<'dien-toan-luong-tu'>);
const postIndex = (Astro.props as any).postIndex;
const prevPost = (Astro.props as any).prevPost;
const nextPost = (Astro.props as any).nextPost;
const allPosts = (await getCollection('dien-toan-luong-tu')).sort(
    (a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
);
const { Content } = await render(post);
---

<BlogPost {...post.data} postIndex={postIndex} prevPost={prevPost} nextPost={nextPost} posts={allPosts} collectionRoute="dien-toan-luong-tu">
	<Content />
</BlogPost>
