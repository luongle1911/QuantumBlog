      >
      <a
        href="/QuantumBlog/gioi-thieu/"
        style="margin-right: 1.5rem; font-weight: 500; transition: color 0.2s;"
        >Giới thiệu</a
      >
      <div class="dropdown">
        <button class="dropbtn">Chủ đề ▾</button>
        <div class="dropdown-content">
          <a href="/QuantumBlog/co-hoc-luong-tu/">⚛️ Cơ Học Lượng Tử</a>
          <a href="/QuantumBlog/dien-toan-luong-tu/">💻 Điện Toán Lượng Tử</a>
