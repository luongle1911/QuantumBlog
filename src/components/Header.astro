    <a
      href="/QuantumBlog/"
      class="logo"
      style="display: flex; align-items: center; gap: 0.5rem;"
    >
      <img src="/QuantumBlog/favicon.ico" alt="Logo" width="50" height="50" />
      Lượng Tử Cơ Bản
    </a>
    <div class="nav-links" style="display: flex; align-items: center;">
      <a
        href="/QuantumBlog/"
        style="margin-right: 0.5rem; font-weight: 500; transition: color 0.2s;"
